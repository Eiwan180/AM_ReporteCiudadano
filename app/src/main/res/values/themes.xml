<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ReporteCiudadano" parent="Theme.MaterialComponents.Light.NoActionBar">

        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_dark</item>
        <item name="colorPrimaryVariant">@color/brand_dark</item>

        <item name="colorSecondary">@color/gold</item>
        <item name="colorSecondaryVariant">@color/gold_light</item>

        <item name="android:colorBackground">@color/bg_cream</item>
        <item name="colorSurface">@color/bg_white</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="colorOnPrimary">@color/text_on_brand</item>

        <item name="colorOnSecondary">@color/text_on_gold</item>

        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>

        <item name="colorControlHighlight">@color/brand_light</item>

        <item name="android:fontFamily">sans-serif</item>

    </style>

    <style name="Theme.ReporteCiudadano.Splash" parent="Theme.ReporteCiudadano">
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:navigationBarColor">@color/brand_primary</item>
    </style>

    <style name="InputStyle.Tangamandapio"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_stroke_selector</item>
        <item name="hintTextColor">@color/brand_primary</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <style name="Btn.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/gold_light</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="Btn.Gold" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/gold</item>
        <item name="android:textColor">@color/brand_dark</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Btn.Success" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/success</item>
        <item name="android:textColor">@color/bg_white</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Btn.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="cornerRadius">10dp</item>
    </style>
</resources>